# =============================================================================
# Supabase configuration
# =============================================================================
# Public — used by both the server and the browser bundle. Safe to expose.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER prefix with NEXT_PUBLIC_ and never import this from a
# client component — Next.js will refuse to inline it into the browser bundle.
# Used only for trusted server actions (e.g. admin operations).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only secret for /api/cron/expire-job-orders.
# Configure the same value in Vercel Cron or your external scheduler.
CRON_SECRET=replace-with-a-long-random-secret
